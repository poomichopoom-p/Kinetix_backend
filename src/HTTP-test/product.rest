### 7. Create a new brand (Admin only)
POST {{baseUrl}}/api/products/admin/newBrand
Cookie: accessToken={{jwtToken}}; token={{jwtToken}}
Content-Type: application/json

{
  "brandName": "Nike"
}

### 8. Delete a product (Admin only)
DELETE {{baseUrl}}/api/products/admin/{{productId}}
Cookie: accessToken={{jwtToken}}; token={{jwtToken}}
Accept: application/json
