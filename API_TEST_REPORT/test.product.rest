  "brandId": "65f1a2b3c4d5e6f7a8b9c0d1", 
  "gender": "men",
  "category": "Road",
  "rentalPlan": [
    {
      "1day": 200,
      "3day": 500,
      "7day": 1000
    }
  ],
  "variants": [
    {
      "skuColorCode": "PEG40-BLK",
      "colorName": "Black",
      "images": "https://example.com/shoe.jpg",
      "size": [
        { "size": 42, "stock": 5 },
        { "size": 43, "stock": 3 }
      ]
    }
  ]
}


